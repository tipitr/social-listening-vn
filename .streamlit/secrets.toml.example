# Streamlit Cloud secrets template — do NOT commit the real version.
#
# In Streamlit Community Cloud:
#   1. Open your app's dashboard
#   2. Click ⋮ (top right) → "Edit secrets"
#   3. Paste the values below (with real keys substituted in)
#   4. Click Save — the app reloads automatically
#
# Locally, copy this file to .streamlit/secrets.toml and fill in.
# .streamlit/secrets.toml is in .gitignore so it stays off GitHub.
#
# Note: Streamlit Cloud exposes everything in secrets.toml to the app as
# environment variables AND as st.secrets["KEY"]. Our code reads from
# os.environ, so the [env] table below is what matters.

[env]

# ── Database ──────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (transaction pooler)
# Format: postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres
DATABASE_URL = "postgresql://postgres.xxxxx:YOURPASSWORD@aws-0-region.pooler.supabase.com:6543/postgres"

# ── Claude (required) ─────────────────────────────────────────────────────
# Categorizes articles + writes the weekly insight report.
# Get a key at https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY = "sk-ant-..."

# ── Firecrawl (optional) ──────────────────────────────────────────────────
# Used as a fallback when a Vietnamese news/forum site blocks plain requests
# or renders content via JavaScript. Without this, those sites are skipped.
# Get a key at https://www.firecrawl.dev
FIRECRAWL_API_KEY = "fc-..."

# ── Facebook Graph API (optional) ─────────────────────────────────────────
# Enables monitoring of bank Facebook pages listed in config/sources.yaml.
# Easiest path: long-lived Page Access Token from Meta Business Suite.
FACEBOOK_ACCESS_TOKEN = ""

# Or, if no user token: a Facebook App's App ID + Secret can pull public
# Page posts. Less reliable.
FACEBOOK_APP_ID     = ""
FACEBOOK_APP_SECRET = ""
